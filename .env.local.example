# ================================================================
# HotShort Local Worker — Configuration
# ================================================================
# Copy this file to .env.local and fill in your values.
# local_worker.py loads .env.local first (falls back to .env).
# This file should NOT be committed to git.
# ================================================================

# --- Required ---

# Your Railway app URL (no trailing slash)
RAILWAY_URL=https://hotshort.up.railway.app

# Shared secret between Railway and this worker.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
# Set the SAME value as WORKER_SECRET on Railway dashboard.
WORKER_SECRET=CHANGE_ME_generate_with_python_secrets_token_hex_32

# --- Cloudinary (same as Railway) ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Groq (same as Railway) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Worker Behaviour ---

# Poll interval in seconds (how often to check for new jobs)
POLL_INTERVAL=5

# --- Whisper / GPU ---
WHISPER_MODEL=base
# Force GPU: cuda | Force CPU: cpu | Auto-detect: leave blank
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8_float16

# --- Pipeline (mirror Railway settings) ---
HS_GROQ_CORTEX_ENABLED=1
HS_GROQ_MIN_SCORE=72
HS_GROQ_MAX_CLIPS=10
HS_ORCH_PIPELINE_MODE=staged
HS_ORCH_TOP_K=8
HS_WORKER_EDITOR_ENABLED=1
HS_WATERMARK_ENABLED=1
HS_WATERMARK_TEXT=HOTSHORT
HS_WATERMARK_FREE_ONLY=1
FREE_GENERATION_LIMIT=1
