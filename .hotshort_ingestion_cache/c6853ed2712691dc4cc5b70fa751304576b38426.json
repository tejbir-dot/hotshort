  "source_transcript_segments": [
    {
      "start": 0.0,
      "end": 4.64,
      "text": "The most important quality you can have in this world today for success, for power, for"
    },
    {
      "start": 4.64,
      "end": 9.56,
      "text": "fulfillment, for happiness is the ability to look inward and ask yourself, why am I"
    },
    {
      "start": 9.56,
      "end": 10.56,
      "text": "doing this?"
    },
    {
      "start": 10.56,
      "end": 11.68,
      "text": "Why do I feel this way?"
    },
    {
      "start": 11.68,
      "end": 14.36,
      "text": "Why am I having these emotional responses?"
    },
    {
      "start": 14.36,
      "end": 15.64,
      "text": "What is my life about?"
    },
    {
      "start": 15.64,
      "end": 16.96,
      "text": "What is the purpose to my life?"
    }
  ],
